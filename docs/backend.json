
{
  "entities": {
    "Obra": {
      "title": "Obra",
      "description": "Representa un proyecto de ingeniería o instalación industrial sincronizado con App Android.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "numeroOF": { "type": "string", "description": "Orden de Fabricación" },
        "numeroOT": { "type": "string", "description": "Orden de Trabajo" },
        "codigoCliente": { "type": "string", "description": "Identificador del cliente" },
        "nombreObra": { "type": "string" },
        "cliente": { "type": "string", "description": "Razón social del cliente" },
        "direccion": { "type": "string" },
        "descripcion": { "type": "string" },
        "usuarioAcceso": { "type": "string", "description": "Email para login en Android" },
        "claveAcceso": { "type": "string" },
        "createdAt": { "type": "number" },
        "serverTimestamp": { "type": "object", "description": "Firebase server timestamp" },
        "authorizedEmails": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "email": { "type": "string" },
              "password": { "type": "string" }
            }
          }
        }
      },
      "required": ["numeroOF", "numeroOT", "nombreObra", "cliente", "usuarioAcceso", "claveAcceso"]
    },
    "UsuarioHabilitado": {
      "title": "Usuario Habilitado",
      "description": "Usuarios externos registrados con acceso a la plataforma web.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nombre": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "password": { "type": "string" }
      },
      "required": ["nombre", "email", "password"]
    },
    "Empresa": {
      "title": "Configuración de Empresa",
      "description": "Datos institucionales de Tamer Industrial S.A. configurables por el administrador.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "razonSocial": { "type": "string" },
        "direccion": { "type": "string" },
        "cuil": { "type": "string" },
        "telefono": { "type": "string" },
        "emailContacto": { "type": "string" },
        "claveContacto": { "type": "string" },
        "logoUrl": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["anonymous", "password"]
  },
  "firestore": {
    "/obras/{obraId}": {
      "schema": "Obra",
      "description": "Colección de proyectos industriales. Lectura permitida para usuarios autenticados (incluyendo anónimos) para soportar el flujo de campo y web."
    },
    "/usuarios_clientes/{usuarioId}": {
      "schema": "UsuarioHabilitado",
      "description": "Usuarios autorizados. Lectura permitida para validación de login anónimo."
    },
    "/config/empresa": {
      "schema": "Empresa",
      "description": "Configuración global de la empresa. Lectura permitida para branding y validación de acceso maestro."
    }
  }
}
